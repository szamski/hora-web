{
  "name": "hora Calendar",
  "short_name": "hora",
  "description": "A native macOS client for Google Calendar. Built with SwiftUI. No Electron. No CalDAV. Just fast.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#0a0a0a",
